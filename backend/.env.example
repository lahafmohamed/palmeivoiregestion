# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/palme_ivoire_gestion

# JWT
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-characters-long
JWT_EXPIRES_IN=24h

# Serveur
PORT=3000
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:3000

# API Gespont
GESPONT_API_URL=http://160.154.143.124:3128
GESPONT_API_KEY=your-api-key-here

# Synchronisation
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=30
